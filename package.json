{
	"name": "llama-vscode-chat-local",
	"publisher": "llama",
	"displayName": "Llama.cpp Provider for GitHub Copilot Chat (Local)",
	"description": "A local Llama.cpp provider for GitHub Copilot Chat",
	"icon": "assets/logo.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/mbeps/llama-vscode-chat"
	},
	"version": "1.0.0",
	"engines": {
		"vscode": "^1.104.0"
	},
	"categories": [
		"AI",
		"Chat"
	],
	"galleryBanner": {
		"color": "#100f11",
		"theme": "dark"
	},
	"badges": [],
	"homepage": "https://github.com/mbeps/llama-vscode-chat",
	"bugs": {
		"url": "https://github.com/mbeps/llama-vscode-chat/issues"
	},
	"license": "MIT",
	"contributes": {
		"languageModelChatProviders": [
			{
				"vendor": "llamacpp",
				"displayName": "Llama.cpp",
				"managementCommand": "llamacpp.manage"
			}
		],
		"commands": [
			{
				"command": "llamacpp.manage",
				"title": "Manage Llama.cpp Provider"
			}
		]
	},
	"main": "./out/extension.js",
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"download-api": "dts dev",
		"postdownload-api": "dts main",
		"postinstall": "npm run download-api",
		"compile": "tsc -p ./",
		"lint": "eslint",
		"format": "prettier --write .",
		"watch": "tsc -watch -p ./",
		"test": "npm run compile && vscode-test"
	},
	"dependencies": {},
	"devDependencies": {
		"@eslint/js": "^9.13.0",
		"@stylistic/eslint-plugin": "^2.9.0",
		"@types/node": "^22",
		"@types/mocha": "^10.0.6",
		"@vscode/dts": "^0.4.1",
		"@types/vscode": "^1.103.0",
		"@vscode/test-cli": "^0.0.11",
		"@vscode/test-electron": "^2.5.2",
		"eslint": "^9.13.0",
		"prettier": "^3.1.0",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.39.0"
	},
	"packageManager": "npm@9.8.1"
}